# PSX Monitor - Environment Variables

# Supabase (required for portfolio sync across devices)
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic (optional — enables live news analysis)
# Get one at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=
